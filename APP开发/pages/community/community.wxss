.container {
  padding: 0;
  background-color: #F5F7F9;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 顶部标题栏 */
.community-header {
  display: flex;
  align-items: center;
  padding: 40rpx 40rpx 20rpx;
  position: relative;
}

.header-side-title {
  font-size: 28rpx;
  color: #91AAB4;
  font-weight: 500;
}

.header-main-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: bold;
  color: #2B4C6F;
}

.header-icons {
  margin-left: auto;
  display: flex;
  gap: 20rpx;
}

.icon-item {
  font-size: 36rpx;
}

/* 顶部活动 Banner */
.special-banner {
  margin: 20rpx 30rpx;
  height: 380rpx;
  background: radial-gradient(circle at 30% 30%, rgba(0, 243, 255, 0.12), transparent 55%),
    linear-gradient(135deg, #0D1B2A 0%, #1B2B3A 55%, #2B4C6F 100%);
  border-radius: 30rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 15rpx 35rpx rgba(26, 42, 58, 0.2);
}

.wuxing-cover {
  position: absolute;
  inset: 0;
  opacity: 1;
  z-index: 1;
}

.wuxing-cover.big {
  border-radius: 26rpx;
  overflow: hidden;
}

.wuxing-orb {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  filter: blur(10rpx);
  opacity: 0.55;
}

.wuxing-cover.big .wuxing-orb {
  width: 180rpx;
  height: 180rpx;
  filter: blur(14rpx);
  opacity: 0.65;
}

.wuxing-orb.wood { background: radial-gradient(circle, rgba(67, 233, 123, 0.9), rgba(67, 233, 123, 0)); left: 40rpx; top: 60rpx; }
.wuxing-orb.fire { background: radial-gradient(circle, rgba(255, 87, 87, 0.9), rgba(255, 87, 87, 0)); right: 60rpx; top: 40rpx; }
.wuxing-orb.earth { background: radial-gradient(circle, rgba(255, 196, 88, 0.9), rgba(255, 196, 88, 0)); left: 50%; top: 50%; transform: translate(-50%, -50%); }
.wuxing-orb.metal { background: radial-gradient(circle, rgba(220, 232, 255, 0.9), rgba(220, 232, 255, 0)); left: 90rpx; bottom: 40rpx; }
.wuxing-orb.water { background: radial-gradient(circle, rgba(79, 172, 254, 0.9), rgba(79, 172, 254, 0)); right: 80rpx; bottom: 60rpx; }

.wuxing-trail {
  position: absolute;
  left: -20%;
  top: 48%;
  width: 140%;
  height: 220rpx;
  background: radial-gradient(circle at 10% 50%, rgba(255,255,255,0.12), transparent 55%),
    linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
  transform: rotate(-6deg);
  filter: blur(6rpx);
  opacity: 0.55;
}

.pixel-banner-content {
  padding: 40rpx;
  color: #fff;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 2;
}

.banner-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.banner-main-title {
  display: flex;
  gap: 15rpx;
  font-size: 56rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
}

.banner-main-title.vertical {
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 46rpx;
  letter-spacing: 2rpx;
}

.title-split {
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.95;
}

.banner-sub-title {
  font-size: 24rpx;
  opacity: 0.8;
  letter-spacing: 2rpx;
}

.read-pill {
  margin-top: 22rpx;
  font-size: 22rpx;
  background: rgba(0,0,0,0.25);
  padding: 10rpx 22rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.18);
  letter-spacing: 1rpx;
}


/* 测试入口 */
.test-entry-container {
  margin: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.test-entry-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2B4C6F;
  margin-bottom: 25rpx;
  letter-spacing: 2rpx;
}

.test-entry-btn {
  background: #000;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  box-shadow: 0 10rpx 25rpx rgba(0,0,0,0.15);
  transition: all 0.3s ease;
}

.test-entry-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.pixel-btn-inner {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.pixel-icon {
  font-size: 36rpx;
}

/* 推荐列表 */
.recommend-section {
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2B4C6F;
}

.more-link {
  font-size: 24rpx;
  color: #91AAB4;
}

.recommend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 25rpx;
}

.grid-item {
  background: #fff;
  border-radius: 25rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 25rpx rgba(145, 170, 180, 0.1);
}

.grid-img-wrapper {
  position: relative;
  height: 260rpx;
}

.grid-img {
  width: 100%;
  height: 100%;
}

.grid-tag-pill {
  position: absolute;
  top: 15rpx;
  left: 15rpx;
  background: rgba(43, 76, 111, 0.8);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  backdrop-filter: blur(5px);
}

.grid-fav-icon {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  font-size: 30rpx;
  text-shadow: 0 2rpx 5rpx rgba(0,0,0,0.2);
}

.grid-info {
  padding: 20rpx;
}

.grid-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2B4C6F;
  margin-bottom: 10rpx;
}

.grid-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.grid-location, .grid-date {
  font-size: 20rpx;
  color: #91AAB4;
}

/* 底部品牌标志 */
.bottom-brand {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

.brand-logo {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.6;
  margin-bottom: 20rpx;
}

.brand-text {
  font-size: 22rpx;
  color: #91AAB4;
  letter-spacing: 2rpx;
}
