.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(104rpx + env(safe-area-inset-bottom));
  padding-bottom: 0;
  background: linear-gradient(180deg, #0D1B2A 0%, #050A14 100%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  z-index: 9999;
}

.tab-inner {
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
}

.tab-icon-wrap {
  width: 150rpx;
  height: 86rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 86rpx;
  height: 86rpx;
  opacity: 0.85;
  filter: brightness(1.25) contrast(1.15);
}

.tab-text {
  position: absolute;
  bottom: 2rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #91AAB4;
  letter-spacing: 1.5rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.6);
}

.active .tab-icon {
  opacity: 1;
  filter: brightness(1.45) contrast(1.2);
}

.active .tab-text {
  color: #00F3FF;
}

