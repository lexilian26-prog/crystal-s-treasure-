<view class="tab-bar">
  <view class="tab-inner">
    <view class="tab-item {{selected === index ? 'active' : ''}}" wx:for="{{list}}" wx:key="pagePath" data-index="{{index}}" bindtap="switchTab">
      <view class="tab-icon-wrap">
        <image class="tab-icon" src="/{{item.icon}}" mode="aspectFit"></image>
        <view class="tab-text">{{item.text}}</view>
      </view>
    </view>
  </view>
</view>

